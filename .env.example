# Copy to .env and adjust. .env is gitignored.

# --- Ollama (local model) ---
OLLAMA_MODEL=qwen3:8b
OLLAMA_HOST=http://localhost:11434
# Context window: Ollama's ~4k default silently truncates Browser Use prompts.
OLLAMA_NUM_CTX=16384
# Per-call LLM timeout; local inference at this context size is slow.
OLLAMA_LLM_TIMEOUT_S=300

# --- Experiment knobs (defaults shown) ---
K=5
MAX_STEPS=15
HEADLESS=true
# Non-zero by design: run-to-run sampling variation is part of the study.
TEMPERATURE=1.0
