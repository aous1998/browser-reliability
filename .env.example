# Copy to .env and fill in. .env is gitignored.

# Backbone provider: "anthropic" (default) or "gemini".
PROVIDER=anthropic

# --- Anthropic (default) ---
ANTHROPIC_API_KEY=your-anthropic-api-key-here
# Cheapest current Claude model:
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- Gemini (alternative) ---
# GOOGLE_API_KEY=your-gemini-api-key-here
# GEMINI_MODEL=gemini-2.5-flash

# Override the judge model (defaults to the agent model):
# JUDGE_MODEL=

# Experiment knobs (defaults shown).
K=3
TAU=0.9
MAX_STEPS=25
HEADLESS=true
