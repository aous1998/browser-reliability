# Copy to .env and fill in. .env is gitignored.

# Backbone provider: "anthropic" (default) or "gemini".
PROVIDER=anthropic

# --- Anthropic (default) ---
ANTHROPIC_API_KEY=your-anthropic-api-key-here
# Cheapest current Claude model:
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- Gemini (alternative) ---
# GOOGLE_API_KEY=your-gemini-api-key-here
# GEMINI_MODEL=gemini-2.5-flash

# --- Ollama (local, free) ---
# PROVIDER=ollama
# OLLAMA_MODEL=qwen3:8b
# Context window: Ollama's ~4k default truncates Browser Use prompts.
# OLLAMA_NUM_CTX=16384

# Override the judge model (defaults to the agent model):
# JUDGE_MODEL=

# Experiment knobs (defaults shown).
K=3
TAU=0.9
MAX_STEPS=25
HEADLESS=true

# Decoding settings, held fixed across runs. Agent temperature is non-zero by
# design (its sampling variation is the phenomenon under study); the judge runs
# deterministically at 0.
TEMPERATURE=1.0
JUDGE_TEMPERATURE=0.0
